# === Supabase ===
# Project URL and anon key from your Supabase project settings.
# Required - the app will refuse to start without these (see src/core/database/supabase.ts).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Security ===
# Encrypts API keys stored via the /api/keys endpoints. Generate with:
#   openssl rand -hex 32
# Required - the app will refuse to start without this (see src/core/security/crypto.ts).
GATEWAY_ENCRYPTION_KEY=

# Shared admin token required to call protected API routes (/api/keys, /api/storage,
# /api/system, /api/gateway, /api/queue, /api/search, /api/analytics, /api/models).
# Send as: Authorization: Bearer <ADMIN_API_TOKEN>
# Required - protected routes return 503 until this is set (see src/middleware.ts).
ADMIN_API_TOKEN=

# === Optional integrations ===
# Redis connection for BullMQ background job processing.
REDIS_URL=redis://localhost:6379

# Qdrant vector database for knowledge base / RAG search.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Virus/malware scanning service endpoint for uploaded files. If unset, files are
# NOT scanned and are indexed as-is (see scanFile() in pipeline.service.ts) -
# metadata will record scanStatus: "not_scanned_no_scanner_configured".
VIRUS_SCAN_API_URL=
